{
  "name": "localstack-demo-lambda",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "esbuild src/handler.ts --bundle --platform=node --target=node18 --outfile=dist/handler.js --external:@aws-sdk/*",
    "package": "npm run build && cd dist && zip -r ../function.zip handler.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0"
  },
  "devDependencies": {
    "esbuild": "^0.21.0",
    "@types/aws-lambda": "^8.10.140",
    "typescript": "^5.5.0"
  }
}
